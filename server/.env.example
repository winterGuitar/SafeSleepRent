# 环境变量配置文件
# 复制此文件为 .env 并填入实际的配置值

# 微信小程序配置
# 请在微信公众平台小程序后台获取 AppID 和 AppSecret
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# 运行环境
# development=开发环境, production=生产环境
NODE_ENV=production

# 数据库配置（可选，如果需要覆盖默认配置）
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=hosp_bed
# DB_USER=beduser
# DB_PASSWORD=123456
