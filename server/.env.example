# Environment variables
# Copy this file to server/.env and fill in real values.

# Runtime
APP_ENV=production
NODE_ENV=production
PORT=3000
SERVER_HOST=0.0.0.0
SERVER_DOMAIN=www.axxzc.cn
BASE_URL=https://www.axxzc.cn
WS_BASE_URL=wss://www.axxzc.cn
ADMIN_BASE_URL=https://www.axxzc.cn
CORS_ALLOWED_ORIGINS=https://www.axxzc.cn,http://localhost:8080,http://localhost:3000

# WeChat mini program
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_TOKEN_SECRET=change_this_admin_token_secret
ADMIN_TOKEN_TTL_MS=86400000

# Database
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hosp_bed
DB_USER=beduser
DB_PASSWORD=123456
DB_CONNECTION_LIMIT=10

# Payment
WECHAT_PAY_APP_ID=your_wx_appid
WECHAT_PAY_MCH_ID=your_mchid
WECHAT_PAY_API_KEY=your_api_key
WECHAT_PAY_NOTIFY_URL=https://www.axxzc.cn/api/payment/notify
ALIPAY_NOTIFY_URL=https://www.axxzc.cn/api/alipay/notify
