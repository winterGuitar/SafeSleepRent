/* order.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 过滤器 */
.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.filter-item.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
}

.order-list {
  padding-bottom: 20rpx;
}

.order-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.order-status.paid {
  background: #e8f7e9;
  color: #07C160;
}

.order-status.refunded {
  background: #e3f2fd;
  color: #2196F3;
}

.order-status.unpaid {
  background: #fff3e0;
  color: #ff6b35;
}

.order-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

.order-beds {
  margin-bottom: 20rpx;
}

.bed-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f9f9f9;
}

.bed-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.bed-qty {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}

.bed-deposit {
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: bold;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-total {
  font-size: 30rpx;
  color: #ff6b35;
  font-weight: bold;
}

.order-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.action-btn:first-child {
  background: #f0f0f0;
  color: #333;
  border: none;
}

.action-btn:last-child {
  background: #07C160;
  color: #fff;
}

.btn-primary {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%) !important;
  color: #fff !important;
}

.btn-cancel {
  background: #f0f0f0 !important;
  color: #666 !important;
}

.refunded-info {
  width: 100%;
  text-align: center;
  padding: 20rpx 0;
  color: #2196F3;
  font-size: 24rpx;
}

.cancelled-info {
  width: 100%;
  text-align: center;
  padding: 20rpx 0;
  color: #999;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}
