/* index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 240rpx;
}

.bed-list {
  padding: 20rpx;
  padding-top: 20rpx;
}

/* 底部区域 */
.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 我的订单按钮栏 */
.order-btn-bar {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: flex-end;
}

.order-btn {
  display: flex;
  align-items: center;
  background: #07C160;
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  transition: all 0.3s;
}

.order-btn:active {
  background: #06AD56;
  transform: scale(0.98);
}

.order-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.order-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.bed-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.bed-item.unavailable {
  opacity: 0.6;
}

.bed-image.disabled {
  filter: grayscale(100%);
}

.unavailable-tag {
  display: inline-block;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
  font-weight: normal;
}

.bed-info {
  display: flex;
}

.bed-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.bed-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bed-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.bed-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.bed-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.bed-price {
  font-size: 36rpx;
  color: #ff6b35;
  font-weight: bold;
  flex-shrink: 0;
}

.price-unit {
  font-size: 24rpx;
}

.price-value {
  font-size: 36rpx;
}

.bed-deposit {
  font-size: 24rpx;
  color: #999;
}

.deposit-label {
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.quantity-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.quantity-control {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 4rpx 8rpx;
  margin-bottom: 4rpx;
}

.stock-info {
  font-size: 22rpx;
  color: #999;
  text-align: right;
}

.qty-btn {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: #fff;
  color: #333;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn::after {
  border: none;
}

.qty-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.qty-minus {
  color: #666;
}

.qty-plus {
  color: #07C160;
}

.qty-value {
  font-size: 28rpx;
  color: #333;
  min-width: 36rpx;
  text-align: center;
  padding: 0 8rpx;
}

.item-pay-area {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.item-pay-btn {
  min-width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  transition: all 0.3s;
}

.item-pay-btn::after {
  border: none;
}

.item-pay-btn.disabled {
  background: #ccc;
  pointer-events: none;
}

.bottom-bar {
  padding: 24rpx;
  background: #fff;
}

.total-info {
  margin-bottom: 20rpx;
  text-align: center;
}

.total-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 30rpx;
}

.deposit-text {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: bold;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.pay-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #fff;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
}

.pay-btn::after {
  border: none;
}

.pay-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}
